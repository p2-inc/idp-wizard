{
  "schemaVersion": "1.0",
  "id": "generic-oidc",
  "providerId": "openid",
  "protocol": "oidc",
  "title": "Generic OpenID Connect",

  "alias": {
    "prefix": "generic-oidc",
    "sessionKey": "p2_openid_oidc"
  },

  "idpConfig": {
    "providerId": "oidc",
    "hideOnLogin": true,
    "defaults": {
      "syncMode": "FORCE",
      "clientAuthMethod": "client_secret_post"
    }
  },

  "steps": [
    {
      "id": 1,
      "title": "Create an Application",
      "blocks": [
        {
          "type": "text",
          "content": "In your identity provider, create a new OpenID Connect application. You'll need the redirect URI below to configure it."
        },
        {
          "type": "copy",
          "label": "Redirect URI",
          "value": "{{api.ssoUrl}}",
          "hint": "Sometimes called Callback URL or Login Redirect URI"
        }
      ]
    },
    {
      "id": 2,
      "title": "Configure Application",
      "enableNextWhen": "state.metadataValidated",
      "blocks": [
        {
          "type": "text",
          "content": "Provide the OpenID Connect configuration for your identity provider. Use the discovery URL if available — it's the easiest option."
        },
        {
          "type": "formGroup",
          "id": "oidcConfigInput",
          "exclusive": true,
          "forms": ["configUrl", "configManual"]
        }
      ]
    },
    {
      "id": 3,
      "title": "Client Credentials",
      "enableNextWhen": "state.credentialsProvided",
      "blocks": [
        {
          "type": "text",
          "content": "Enter the client ID and secret generated by your identity provider when you created the application."
        },
        {
          "type": "formGroup",
          "id": "clientCredentials",
          "exclusive": false,
          "forms": ["clientCredentials"]
        }
      ]
    },
    {
      "id": 4,
      "title": "Configure User Access",
      "blocks": [
        {
          "type": "text",
          "content": "Assign the users or groups who should have access in your identity provider, then continue."
        }
      ]
    },
    {
      "id": 5,
      "title": "Confirmation",
      "type": "confirm",
      "blocks": [
        {
          "type": "confirm",
          "title": "Create OpenID Connect Identity Provider",
          "description": "Configuration is complete. Click the button below to create the identity provider in Keycloak.",
          "buttonText": "Create OIDC Identity Provider",
          "action": "createIdp",
          "adminLink": "{{api.adminLinkOidc}}",
          "adminButtonText": "Manage OIDC Identity Provider"
        }
      ]
    }
  ],

  "forms": {
    "configUrl": {
      "title": "Discovery URL",
      "description": "Paste the OpenID Connect discovery URL (/.well-known/openid-configuration) from your identity provider.",
      "fields": [
        {
          "id": "url",
          "type": "url",
          "label": "Discovery URL",
          "placeholder": "https://your-idp.example.com/.well-known/openid-configuration",
          "required": true
        }
      ],
      "submit": {
        "label": "Fetch Configuration",
        "action": "validateConfigUrl"
      }
    },

    "configManual": {
      "title": "Manual Configuration",
      "description": "Enter the authorization, token, and optional userinfo endpoint URLs directly.",
      "fields": [
        {
          "id": "authorizationUrl",
          "type": "url",
          "label": "Authorization URL",
          "placeholder": "https://your-idp.example.com/oauth/authorize",
          "required": true
        },
        {
          "id": "tokenUrl",
          "type": "url",
          "label": "Token URL",
          "placeholder": "https://your-idp.example.com/oauth/token",
          "required": true
        },
        {
          "id": "userInfoUrl",
          "type": "url",
          "label": "UserInfo URL",
          "placeholder": "https://your-idp.example.com/oauth/userinfo",
          "required": false
        },
        {
          "id": "issuer",
          "type": "text",
          "label": "Issuer",
          "placeholder": "https://your-idp.example.com",
          "required": false
        }
      ],
      "submit": {
        "label": "Save Configuration",
        "action": "validateConfigManual"
      }
    },

    "clientCredentials": {
      "title": "Client Credentials",
      "description": "Enter the client ID and client secret from your identity provider.",
      "fields": [
        {
          "id": "clientId",
          "type": "text",
          "label": "Client ID",
          "placeholder": "your-client-id",
          "required": true
        },
        {
          "id": "clientSecret",
          "type": "password",
          "label": "Client Secret",
          "placeholder": "your-client-secret",
          "required": true
        }
      ],
      "submit": {
        "label": "Save Credentials",
        "action": "saveClientCredentials"
      }
    }
  },

  "actions": {
    "validateConfigUrl": {
      "endpoint": "importConfig",
      "method": "POST",
      "contentType": "json",
      "body": {
        "fromUrl": "{{form.url}}",
        "providerId": "oidc"
      },
      "onSuccess": {
        "mergeIntoMetadata": "{{response}}",
        "dispatch": ["METADATA_VALIDATED"]
      },
      "messages": {
        "success": "Configuration fetched. Continue to set your client credentials.",
        "error": "Could not fetch configuration. Check the discovery URL and try again."
      }
    },

    "validateConfigManual": {
      "endpoint": "importConfig",
      "method": "POST",
      "contentType": "json",
      "body": {
        "authorizationUrl": "{{form.authorizationUrl}}",
        "tokenUrl": "{{form.tokenUrl}}",
        "userInfoUrl": "{{form.userInfoUrl}}",
        "issuer": "{{form.issuer}}",
        "providerId": "oidc"
      },
      "onSuccess": {
        "mergeIntoMetadata": "{{response}}",
        "dispatch": ["METADATA_VALIDATED"]
      },
      "messages": {
        "success": "Configuration saved. Continue to set your client credentials.",
        "error": "Could not validate the configuration. Check the URLs and try again."
      }
    },

    "saveClientCredentials": {
      "type": "saveForm",
      "dispatch": ["CREDENTIALS_PROVIDED"],
      "fields": ["clientId", "clientSecret"]
    },

    "createIdp": {
      "endpoint": "createIdp",
      "method": "POST",
      "contentType": "json",
      "body": {
        "alias": "{{alias}}",
        "displayName": "{{alias}}",
        "providerId": "oidc",
        "hideOnLogin": true,
        "config": {
          "$spread": "{{state.metadata}}",
          "syncMode": "FORCE",
          "clientAuthMethod": "client_secret_post",
          "clientId": "{{state.formValues.clientId}}",
          "clientSecret": "{{state.formValues.clientSecret}}"
        }
      },
      "onSuccess": {
        "dispatch": [
          { "type": "SUBMIT_SUCCESS", "result": "OIDC Identity Provider created successfully." }
        ],
        "then": ["clearAlias"]
      },
      "messages": {
        "error": "Error creating Identity Provider. One may already be configured for this realm."
      }
    },

    "clearAlias": {
      "type": "clearAlias"
    }
  }
}
