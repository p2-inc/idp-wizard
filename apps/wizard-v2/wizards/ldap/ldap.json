{
  "schemaVersion": "1.0",
  "id": "generic-ldap",
  "providerId": "ldap",
  "protocol": "ldap",
  "title": "Generic LDAP",

  "alias": {
    "prefix": "generic-ldap",
    "sessionKey": "p2_ldap_ldap"
  },

  "idpConfig": {
    "providerId": "ldap",
    "hideOnLogin": false,
    "defaults": {
      "editMode": "READ_ONLY",
      "vendor": "other",
      "searchScope": "1",
      "authType": "simple",
      "useTruststoreSpi": "ldapsOnly",
      "connectionPooling": "true",
      "pagination": "true",
      "batchSizeForSync": "1000",
      "fullSyncPeriod": "-1",
      "changedSyncPeriod": "-1",
      "cachePolicy": "DEFAULT",
      "importEnabled": "true",
      "syncRegistrations": "false"
    }
  },

  "steps": [
    {
      "id": 1,
      "title": "Server Details",
      "enableNextWhen": "state.connectionTested",
      "blocks": [
        {
          "type": "text",
          "content": "Enter the connection details for your LDAP server. The connection will be tested before you can proceed."
        },
        {
          "type": "formGroup",
          "id": "serverDetails",
          "exclusive": false,
          "forms": ["serverConfig"]
        }
      ]
    },
    {
      "id": 2,
      "title": "Authentication",
      "enableNextWhen": "state.authTested",
      "blocks": [
        {
          "type": "text",
          "content": "Enter the bind DN and password used to authenticate to the LDAP server."
        },
        {
          "type": "formGroup",
          "id": "bindConfig",
          "exclusive": false,
          "forms": ["bindCredentials"]
        }
      ]
    },
    {
      "id": 3,
      "title": "Schema & Mapping",
      "blocks": [
        {
          "type": "text",
          "content": "Configure how LDAP user attributes map to Keycloak fields."
        },
        {
          "type": "attributeTable",
          "rows": [
            { "idpAttribute": "uid / sAMAccountName", "keycloakAttribute": "username" },
            { "idpAttribute": "mail",                  "keycloakAttribute": "email"    },
            { "idpAttribute": "givenName / cn",        "keycloakAttribute": "firstName"},
            { "idpAttribute": "sn",                    "keycloakAttribute": "lastName" }
          ]
        },
        {
          "type": "formGroup",
          "id": "schemaConfig",
          "exclusive": false,
          "forms": ["ldapSchema"]
        }
      ]
    },
    {
      "id": 4,
      "title": "Confirmation",
      "type": "confirm",
      "blocks": [
        {
          "type": "confirm",
          "title": "Create LDAP User Federation",
          "description": "Configuration is complete. Click the button below to create the LDAP user federation provider in Keycloak and trigger an initial user sync.",
          "buttonText": "Create LDAP User Federation",
          "action": "createComponent",
          "adminLink": "",
          "adminButtonText": "Manage User Federation"
        }
      ]
    }
  ],

  "forms": {
    "serverConfig": {
      "title": "Server Configuration",
      "description": "Enter your LDAP server host and base DN. SSL (LDAPS) is required.",
      "fields": [
        {
          "id": "host",
          "type": "text",
          "label": "LDAP Host",
          "placeholder": "ldap.your-company.com",
          "required": true
        },
        {
          "id": "port",
          "type": "text",
          "label": "SSL Port",
          "placeholder": "636",
          "required": true
        },
        {
          "id": "baseDn",
          "type": "text",
          "label": "Base DN",
          "placeholder": "DC=your-company,DC=com",
          "required": true
        },
        {
          "id": "usersDn",
          "type": "text",
          "label": "Users DN",
          "placeholder": "OU=Users,DC=your-company,DC=com",
          "required": true
        }
      ],
      "submit": {
        "label": "Test Connection",
        "action": "testLdapConnection"
      }
    },

    "bindCredentials": {
      "title": "Bind Credentials",
      "description": "The service account used to read from your directory.",
      "fields": [
        {
          "id": "bindDn",
          "type": "text",
          "label": "Bind DN",
          "placeholder": "CN=svc-keycloak,OU=ServiceAccounts,DC=your-company,DC=com",
          "required": true
        },
        {
          "id": "bindPassword",
          "type": "password",
          "label": "Bind Password",
          "placeholder": "••••••••",
          "required": true
        }
      ],
      "submit": {
        "label": "Test Authentication",
        "action": "testLdapAuth"
      }
    },

    "ldapSchema": {
      "title": "Schema Settings",
      "description": "Configure the LDAP attributes used to identify users. Leave as defaults for most directories.",
      "fields": [
        {
          "id": "usernameLdapAttribute",
          "type": "text",
          "label": "Username LDAP Attribute",
          "placeholder": "uid",
          "required": true
        },
        {
          "id": "rdnLdapAttribute",
          "type": "text",
          "label": "RDN LDAP Attribute",
          "placeholder": "uid",
          "required": true
        },
        {
          "id": "uuidLdapAttribute",
          "type": "text",
          "label": "UUID LDAP Attribute",
          "placeholder": "entryUUID",
          "required": true
        },
        {
          "id": "userObjectClasses",
          "type": "text",
          "label": "User Object Classes",
          "placeholder": "inetOrgPerson, organizationalPerson",
          "required": true
        }
      ],
      "submit": {
        "label": "Save Schema",
        "action": "saveLdapSchema"
      }
    }
  },

  "actions": {
    "testLdapConnection": {
      "endpoint": "testLdapConnection",
      "method": "POST",
      "contentType": "json",
      "body": {
        "action": "testConnection",
        "connectionUrl": "ldaps://{{form.host}}:{{form.port}}",
        "authType": "simple",
        "bindDn": "",
        "bindCredential": "",
        "useTruststoreSpi": "ldapsOnly",
        "connectionTimeout": "",
        "startTls": ""
      },
      "onSuccess": {
        "mergeIntoMetadata": "{{response}}",
        "dispatch": ["CONNECTION_TESTED"]
      },
      "messages": {
        "success": "Connection successful. Continue to enter your bind credentials.",
        "error": "Connection failed. Check the host and port and try again."
      }
    },

    "testLdapAuth": {
      "endpoint": "testLdapConnection",
      "method": "POST",
      "contentType": "json",
      "body": {
        "action": "testAuthentication",
        "connectionUrl": "ldaps://{{state.formValues.host}}:{{state.formValues.port}}",
        "authType": "simple",
        "bindDn": "{{form.bindDn}}",
        "bindCredential": "{{form.bindPassword}}",
        "useTruststoreSpi": "ldapsOnly",
        "connectionTimeout": "",
        "startTls": ""
      },
      "onSuccess": {
        "dispatch": ["AUTH_TESTED"]
      },
      "messages": {
        "success": "Authentication successful. Continue to configure schema mapping.",
        "error": "Authentication failed. Check your bind DN and password."
      }
    },

    "saveLdapSchema": {
      "type": "saveForm",
      "dispatch": ["SCHEMA_SAVED"],
      "fields": ["usernameLdapAttribute", "rdnLdapAttribute", "uuidLdapAttribute", "userObjectClasses"]
    },

    "createComponent": {
      "endpoint": "createComponent",
      "method": "POST",
      "contentType": "json",
      "body": {
        "name": "ldap",
        "providerId": "ldap",
        "providerType": "org.keycloak.storage.UserStorageProvider",
        "config": {
          "enabled": ["true"],
          "priority": ["0"],
          "editMode": ["READ_ONLY"],
          "importEnabled": ["true"],
          "syncRegistrations": ["false"],
          "vendor": ["other"],
          "usernameLDAPAttribute": ["{{state.usernameLdapAttribute}}"],
          "rdnLDAPAttribute": ["{{state.rdnLdapAttribute}}"],
          "uuidLDAPAttribute": ["{{state.uuidLdapAttribute}}"],
          "userObjectClasses": ["{{state.userObjectClasses}}"],
          "connectionUrl": ["ldaps://{{state.formValues.host}}:{{state.formValues.port}}"],
          "usersDn": ["{{state.formValues.usersDn}}"],
          "authType": ["simple"],
          "bindDn": ["{{state.formValues.bindDn}}"],
          "bindCredential": ["{{state.formValues.bindPassword}}"],
          "searchScope": ["1"],
          "useTruststoreSpi": ["ldapsOnly"],
          "connectionPooling": ["true"],
          "pagination": ["true"],
          "batchSizeForSync": ["1000"],
          "fullSyncPeriod": ["-1"],
          "changedSyncPeriod": ["-1"],
          "cachePolicy": ["DEFAULT"]
        }
      },
      "onSuccess": {
        "mergeIntoMetadata": "{{response}}",
        "dispatch": [
          { "type": "SUBMIT_SUCCESS", "result": "LDAP User Federation created successfully." }
        ],
        "then": ["triggerSync"]
      },
      "messages": {
        "error": "Error creating LDAP user federation. Check the configuration and try again."
      }
    },

    "triggerSync": {
      "endpoint": "triggerSync",
      "method": "POST",
      "contentType": "json",
      "body": {
        "action": "triggerChangedUsersSync"
      },
      "messages": {
        "error": "User federation created but initial sync could not be triggered."
      }
    }
  }
}
