{
  "schemaVersion": "1.0",
  "id": "entraid-saml",
  "providerId": "entraid",
  "protocol": "saml",
  "title": "Microsoft Entra ID SAML",
  "alias": {
    "prefix": "entraid-saml",
    "sessionKey": "p2_entraid_saml"
  },
  "idpConfig": {
    "providerId": "saml",
    "hideOnLogin": true,
    "defaults": {
      "syncMode": "FORCE",
      "allowCreate": "true",
      "nameIDPolicyFormat": "urn:oasis:names:tc:SAML:1.1:nameid-format:unspecified",
      "principalType": "SUBJECT"
    }
  },
  "steps": [
    {
      "id": 1,
      "title": "Create a SAML Application",
      "blocks": [
        {
          "type": "text",
          "content": "In the Microsoft Entra admin center, create an Enterprise Application and set up SAML-based SSO. Enter the following values in the Basic SAML Configuration."
        },
        {
          "type": "copy",
          "label": "ACS URL",
          "value": "{{api.ssoUrl}}",
          "hint": "Sometimes called SSO Service URL or Callback URL"
        },
        {
          "type": "copy",
          "label": "Entity ID",
          "value": "{{api.entityId}}",
          "hint": "Sometimes called Audience URI or SP Entity ID"
        },
        {
          "type": "copy",
          "label": "SAML Metadata URL",
          "value": "{{api.samlMetadata}}",
          "hint": "Sometimes called Entity Provider Metadata or Descriptor URL"
        },
        {
          "type": "image",
          "src": "/wizards/msft_entra_id/saml/azure-1.png"
        },
        {
          "type": "image",
          "src": "/wizards/msft_entra_id/saml/azure-2.png"
        },
        {
          "type": "image",
          "src": "/wizards/msft_entra_id/saml/azure-3a.png"
        },
        {
          "type": "image",
          "src": "/wizards/msft_entra_id/saml/azure-3.png"
        },
        {
          "type": "image",
          "src": "/wizards/msft_entra_id/saml/azure-4.png"
        },
        {
          "type": "image",
          "src": "/wizards/msft_entra_id/saml/azure-5.png"
        },
        {
          "type": "image",
          "src": "/wizards/msft_entra_id/saml/azure-5a.png"
        },
        {
          "type": "image",
          "src": "/wizards/msft_entra_id/saml/azure-6.png"
        }
      ]
    },
    {
      "id": 2,
      "title": "Configure Application Metadata",
      "enableNextWhen": "state.metadataValidated",
      "blocks": [
        {
          "type": "text",
          "content": "Copy the App Federation Metadata URL from the SAML Signing Certificate section of your Entra application."
        },
        {
          "type": "image",
          "src": "/wizards/msft_entra_id/saml/azure-1a.png"
        },
        {
          "type": "formGroup",
          "id": "metadataInput",
          "exclusive": false,
          "forms": [
            "metadataUrl"
          ]
        }
      ]
    },
    {
      "id": 3,
      "title": "Configure Attribute Mapping",
      "blocks": [
        {
          "type": "text",
          "content": "Configure your identity provider to send the following SAML attributes."
        },
        {
          "type": "attributeTable",
          "rows": [
            {
              "idpAttribute": "username",
              "keycloakAttribute": "username"
            },
            {
              "idpAttribute": "email",
              "keycloakAttribute": "email"
            },
            {
              "idpAttribute": "firstName",
              "keycloakAttribute": "firstName"
            },
            {
              "idpAttribute": "lastName",
              "keycloakAttribute": "lastName"
            }
          ]
        },
        {
          "type": "image",
          "src": "/wizards/msft_entra_id/saml/azure-7.png"
        },
        {
          "type": "image",
          "src": "/wizards/msft_entra_id/saml/azure-8.png"
        },
        {
          "type": "image",
          "src": "/wizards/msft_entra_id/saml/entraid-1.png"
        }
      ]
    },
    {
      "id": 4,
      "title": "Configure User Access",
      "blocks": [
        {
          "type": "text",
          "content": "Assign the users or groups who should have access in your identity provider, then continue."
        },
        {
          "type": "image",
          "src": "/wizards/msft_entra_id/saml/azure-9.png"
        },
        {
          "type": "image",
          "src": "/wizards/msft_entra_id/saml/azure-10.png"
        },
        {
          "type": "image",
          "src": "/wizards/msft_entra_id/saml/azure-11.png"
        },
        {
          "type": "image",
          "src": "/wizards/msft_entra_id/saml/azure-12.png"
        }
      ]
    },
    {
      "id": 5,
      "title": "Confirmation",
      "type": "confirm",
      "blocks": [
        {
          "type": "confirm",
          "title": "Create SAML Identity Provider",
          "description": "Configuration is complete. Click the button below to create the identity provider in Keycloak.",
          "buttonText": "Create SAML Identity Provider",
          "action": "createIdp",
          "adminLink": "{{api.adminLinkSaml}}",
          "adminButtonText": "Manage SAML Identity Provider"
        }
      ]
    }
  ],
  "forms": {
    "metadataUrl": {
      "title": "Metadata URL",
      "description": "Paste the SAML metadata URL provided by your identity provider.",
      "fields": [
        {
          "id": "url",
          "type": "url",
          "label": "Metadata URL",
          "placeholder": "https://login.microsoftonline.com/your-tenant-id/federationmetadata/2007-06/federationmetadata.xml",
          "required": true
        }
      ],
      "submit": {
        "label": "Validate URL",
        "action": "validateMetadataUrl"
      }
    }
  },
  "actions": {
    "validateMetadataUrl": {
      "endpoint": "importConfig",
      "method": "POST",
      "contentType": "json",
      "body": {
        "fromUrl": "{{form.url}}",
        "providerId": "saml"
      },
      "onSuccess": {
        "mergeIntoMetadata": "{{response}}",
        "dispatch": [
          "METADATA_VALIDATED"
        ]
      },
      "messages": {
        "success": "Metadata URL validated. Continue to the next step.",
        "error": "Validation failed. Check the URL and try again."
      }
    },
    "createIdp": {
      "endpoint": "createIdp",
      "method": "POST",
      "contentType": "json",
      "body": {
        "alias": "{{alias}}",
        "displayName": "{{alias}}",
        "providerId": "saml",
        "hideOnLogin": true,
        "config": "{{state.metadata}}"
      },
      "onSuccess": {
        "dispatch": [
          {
            "type": "SUBMIT_SUCCESS",
            "result": "SAML Identity Provider created successfully."
          }
        ],
        "then": [
          "addSamlMappers",
          "clearAlias"
        ]
      },
      "messages": {
        "error": "Error creating Identity Provider. One may already be configured for this realm."
      }
    },
    "addSamlMappers": {
      "endpoint": "addMappers",
      "method": "POST",
      "contentType": "json",
      "foreach": [
        {
          "attributeName": "username",
          "friendlyName": "username",
          "userAttribute": "username"
        },
        {
          "attributeName": "email",
          "friendlyName": "email",
          "userAttribute": "email"
        },
        {
          "attributeName": "firstName",
          "friendlyName": "firstName",
          "userAttribute": "firstName"
        },
        {
          "attributeName": "lastName",
          "friendlyName": "lastName",
          "userAttribute": "lastName"
        }
      ],
      "body": {
        "identityProviderAlias": "{{alias}}",
        "identityProviderMapper": "saml-user-attribute-idp-mapper",
        "name": "{{item.userAttribute}}",
        "config": {
          "syncMode": "INHERIT",
          "attributes": "[]",
          "attribute.name": "{{item.attributeName}}",
          "attribute.friendly.name": "{{item.friendlyName}}",
          "user.attribute": "{{item.userAttribute}}"
        }
      }
    },
    "clearAlias": {
      "type": "clearAlias"
    }
  }
}
