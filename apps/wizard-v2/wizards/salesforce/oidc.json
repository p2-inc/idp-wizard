{
  "schemaVersion": "1.0",
  "id": "salesforce-oidc",
  "providerId": "salesforce",
  "protocol": "oidc",
  "title": "Salesforce OpenID Connect",
  "alias": { "prefix": "salesforce-oidc", "sessionKey": "p2_salesforce_oidc" },
  "idpConfig": {
    "providerId": "oidc",
    "hideOnLogin": true,
    "defaults": { "syncMode": "FORCE", "clientAuthMethod": "client_secret_post" }
  },
  "steps": [
    {
      "id": 1,
      "title": "Create a Connected App",
      "blocks": [
        {
          "type": "text",
          "content": "In Salesforce Setup, navigate to App Manager and create a new Connected App. Enable OAuth Settings and note the Consumer Key and Consumer Secret."
        }
      ]
    },
    {
      "id": 2,
      "title": "Configure OAuth Settings",
      "blocks": [
        {
          "type": "text",
          "content": "In your Connected App's OAuth settings, add the following redirect URI to the Callback URLs."
        },
        {
          "type": "copy",
          "label": "Redirect URI",
          "value": "{{api.ssoUrl}}",
          "hint": "Add this as a Callback URL in Salesforce"
        }
      ]
    },
    {
      "id": 3,
      "title": "Domain & Credentials",
      "enableNextWhen": "state.metadataValidated",
      "blocks": [
        {
          "type": "text",
          "content": "Enter your Salesforce instance domain and the consumer credentials from your Connected App."
        },
        {
          "type": "formGroup",
          "id": "sfCreds",
          "exclusive": false,
          "forms": ["domainCredentials"]
        }
      ]
    },
    {
      "id": 4,
      "title": "Confirmation",
      "type": "confirm",
      "blocks": [
        {
          "type": "confirm",
          "title": "Create Salesforce Identity Provider",
          "description": "Configuration is complete. Click the button below to create the identity provider in Keycloak.",
          "buttonText": "Create OIDC Identity Provider",
          "action": "createIdp",
          "adminLink": "{{api.adminLinkOidc}}",
          "adminButtonText": "Manage OIDC Identity Provider"
        }
      ]
    }
  ],
  "forms": {
    "domainCredentials": {
      "title": "Salesforce Credentials",
      "description": "Enter your Salesforce domain and consumer credentials.",
      "fields": [
        {
          "id": "domain",
          "type": "text",
          "label": "Salesforce Domain",
          "placeholder": "your-instance.my.salesforce.com",
          "required": true
        },
        {
          "id": "clientId",
          "type": "text",
          "label": "Consumer Key",
          "placeholder": "your-consumer-key",
          "required": true
        },
        {
          "id": "clientSecret",
          "type": "password",
          "label": "Consumer Secret",
          "placeholder": "your-consumer-secret",
          "required": true
        }
      ],
      "submit": { "label": "Verify & Save", "action": "validateDomainCredentials" }
    }
  },
  "actions": {
    "validateDomainCredentials": {
      "endpoint": "importConfig",
      "method": "POST",
      "contentType": "json",
      "body": {
        "fromUrl": "https://{{form.domain}}/.well-known/openid-configuration",
        "providerId": "oidc"
      },
      "onSuccess": {
        "mergeIntoMetadata": "{{response}}",
        "dispatch": ["METADATA_VALIDATED", "CREDENTIALS_PROVIDED"]
      },
      "messages": {
        "success": "Salesforce configuration verified. You can now create the identity provider.",
        "error": "Could not fetch configuration. Check the Salesforce domain and try again."
      }
    },
    "createIdp": {
      "endpoint": "createIdp",
      "method": "POST",
      "contentType": "json",
      "body": {
        "alias": "{{alias}}",
        "displayName": "{{alias}}",
        "providerId": "oidc",
        "hideOnLogin": true,
        "config": {
          "syncMode": "FORCE",
          "clientAuthMethod": "client_secret_post",
          "clientId": "{{state.formValues.clientId}}",
          "clientSecret": "{{state.formValues.clientSecret}}",
          "$spread": "{{state.metadata}}"
        }
      },
      "onSuccess": {
        "dispatch": [
          {
            "type": "SUBMIT_SUCCESS",
            "result": "Salesforce Identity Provider created successfully."
          }
        ],
        "then": ["clearAlias"]
      },
      "messages": {
        "error": "Error creating Identity Provider. One may already be configured for this realm."
      }
    },
    "clearAlias": { "type": "clearAlias" }
  }
}
