{
  "schemaVersion": "0.1",
  "id": "generic-saml",
  "provider": "saml",
  "protocol": "saml",
  "title": "Generic SAML wizard",
  "commonName": "Saml Identity Provider",
  "logo": "images/provider-logos/saml_logo.svg",
  "alias": {
    "preface": "generic-saml",
    "storageKey": "p2_saml_saml"
  },
  "constants": {
    "SamlIDPDefaults": {
      "syncMode": "FORCE",
      "allowCreate": "true",
      "nameIDPolicyFormat": "urn:oasis:names:tc:SAML:1.1:nameid-format:unspecified",
      "principalType": "SUBJECT"
    }
  },
  "context": {
    "sources": {
      "api": {
        "alias": "useApi.alias",
        "loginRedirectURL": "useApi.loginRedirectURL",
        "entityId": "useApi.entityId",
        "adminLinkSaml": "useApi.adminLinkSaml",
        "identifierURL": "useApi.identifierURL",
        "createIdPUrl": "useApi.createIdPUrl"
      },
      "keycloak": {
        "serverUrl": "useKeycloakAdminApi.getServerUrl",
        "realm": "useKeycloakAdminApi.getRealm"
      },
      "featureFlags": "useGetFeatureFlagsQuery",
      "displayName": {
        "type": "generateIdpDisplayName",
        "inputRef": "context.api.alias"
      }
    },
    "derived": {
      "ssoUrl": { "ref": "context.api.loginRedirectURL" },
      "entityId": { "ref": "context.api.entityId" },
      "samlMetadata": {
        "template": "{{context.keycloak.serverUrl}}/realms/{{context.keycloak.realm}}/protocol/saml/descriptor"
      }
    }
  },
  "state": {
    "stepIdReached": 1,
    "metadata": null,
    "metadataUrl": "",
    "formValid": false,
    "results": "",
    "error": null,
    "disableButton": false,
    "idpTestLink": ""
  },
  "wizard": {
    "finishStep": 5,
    "nextButtonText": "Continue to Next Step",
    "unsavedPrompt": {
      "message": "The wizard is incomplete. Leaving will lose any saved progress. Are you sure?",
      "enabledWhen": "state.stepIdReached < wizard.finishStep"
    },
    "onClose": "navigateToBasePath",
    "onNext": {
      "type": "sequence",
      "steps": [
        {
          "if": "state.stepIdReached == wizard.finishStep",
          "then": ["clearAlias", "navigateToBasePath"]
        },
        {
          "setState": {
            "stepIdReached": "max(state.stepIdReached, wizard.nextStepId)"
          }
        }
      ]
    }
  },
  "steps": [
    {
      "id": 1,
      "name": "Create a SAML Application",
      "title": "Step 1: Create a SAML Application",
      "nav": {
        "hideCancelButton": true
      },
      "blocks": [
        {
          "type": "text",
          "value": "In your identity provider, create a SAML Application. You may need the following information in order to create and configure your application. Don't worry if you are not asked for these, as not all providers require everything."
        },
        {
          "type": "clipboard",
          "label": "Copy the ACS URL",
          "valueRef": "context.derived.ssoUrl",
          "helperText": "Note that \"sometimes called SSO Service URL\""
        },
        {
          "type": "clipboard",
          "label": "Copy the Entity ID",
          "valueRef": "context.derived.entityId",
          "helperText": "Note that sometimes called \"Audience URI\""
        },
        {
          "type": "clipboard",
          "label": "Copy the SAML Metadata",
          "valueRef": "context.derived.samlMetadata",
          "helperText": "Note that \"sometimes called Entity Provider Metadata or Descriptor\""
        }
      ]
    },
    {
      "id": 2,
      "name": "Configure Application Metadata",
      "title": "Step 2: Configure Application Metadata",
      "nav": {
        "hideCancelButton": true,
        "canJumpToWhen": "state.stepIdReached >= 2",
        "enableNextWhen": "state.formValid == true"
      },
      "blocks": [
        {
          "type": "text",
          "value": "Your identity provider should provide you with configuration information in the form of a metadata url, metadata file, or a few configuration parameters."
        },
        {
          "type": "formGroup",
          "groupId": "metadataInput",
          "exclusive": true,
          "forms": ["metadataUrl", "metadataFile", "metadataConfig"]
        }
      ]
    },
    {
      "id": 3,
      "name": "Configure Attribute Mapping",
      "title": "Step 3: Configure Attribute Mapping",
      "nav": {
        "hideCancelButton": true,
        "canJumpToWhen": "state.stepIdReached >= 3"
      },
      "blocks": [
        {
          "type": "text",
          "value": "Attribute, or SAML Claims mapping allows the information about the user to be correctly mapped from the source identity provider to your application. The values on the left will be specific to your identity provider."
        },
        {
          "type": "doubleClipboard",
          "pairs": [
            { "left": "IdP username", "right": "username" },
            { "left": "IdP email", "right": "email" },
            { "left": "IdP first name", "right": "firstName" },
            { "left": "IdP last name", "right": "lastName" }
          ]
        }
      ]
    },
    {
      "id": 4,
      "name": "Configure User Access",
      "title": "Step 4: Configure User Access",
      "nav": {
        "hideCancelButton": true,
        "canJumpToWhen": "state.stepIdReached >= 4"
      },
      "blocks": [
        {
          "type": "text",
          "value": "It may be necessary to enable your new SAML application, and associate users and groups with it in order for your users to be able to log in to your application. Continue when you have configured user access for your new SAML application in your identity provider."
        }
      ]
    },
    {
      "id": 5,
      "name": "Confirmation",
      "type": "confirmation",
      "nav": {
        "hideCancelButton": true,
        "nextButtonText": "Finish",
        "enableNextWhen": "state.stepIdReached == wizard.finishStep",
        "canJumpToWhen": "state.stepIdReached >= 5"
      },
      "confirmation": {
        "title": "SSO Configuration Complete. Create Identity Provider.",
        "message": "SAML.",
        "buttonText": "Create Saml Identity Provider",
        "adminLinkRef": "context.api.adminLinkSaml",
        "adminButtonText": "Manage Saml Identity Provider",
        "resultsTextRef": "state.results",
        "errorRef": "state.error",
        "disableButtonRef": "state.disableButton",
        "idpTestLinkRef": "state.idpTestLink",
        "validationAction": "createIdp"
      }
    }
  ],
  "forms": {
    "metadataUrl": {
      "title": "Metadata URL",
      "description": "If your identity provider provides a SAML metadata URL, input it here.",
      "fields": [
        {
          "id": "url",
          "type": "url",
          "label": "URL",
          "required": true,
          "validation": {
            "regex": "^(https?:\\/\\/)(localhost|([\\-\\w]+\\.)*\\w+)(:\\d+)?(\\/[-\\w@:%._\\+~#=]+)*(\\/[\\w\\/\\]*)*(\\?.*)?(#.*)?$",
            "message": "URL should be a valid URL."
          }
        }
      ],
      "submit": {
        "label": "Validate URL",
        "action": "validateMetadataUrl"
      }
    },
    "metadataFile": {
      "title": "Metadata File",
      "description": "If your identity provider provides a SAML metadata File, upload it here.",
      "fields": [
        {
          "id": "metadataFile",
          "type": "file",
          "label": "Metadata File",
          "required": true,
          "accept": "text/xml, application/json",
          "placeholder": "Drop or choose metadata file .xml to upload."
        }
      ],
      "submit": {
        "label": "Validate Metadata File",
        "action": "validateMetadataFile"
      }
    },
    "metadataConfig": {
      "title": "Configuration Information",
      "description": "If your identity provider provides a SAML metadata URL, Entity ID, and Certificate, input those below.",
      "fields": [
        {
          "id": "ssoUrl",
          "type": "url",
          "label": "SSO URL",
          "required": true,
          "validation": {
            "type": "url",
            "message": "SSO URL should be a valid URL."
          }
        },
        {
          "id": "entityId",
          "type": "text",
          "label": "Entity Id",
          "required": true
        },
        {
          "id": "metadataFile",
          "type": "file",
          "label": "Certificate File",
          "required": true,
          "placeholder": "Drop or choose certificate file (.pem, etc) to upload."
        }
      ],
      "submit": {
        "label": "Validate Metadata File",
        "action": "validateMetadataConfig"
      }
    }
  },
  "actions": {
    "validateMetadataUrl": {
      "type": "http",
      "request": {
        "method": "POST",
        "urlRef": "context.api.identifierURL",
        "body": {
          "fromUrl": "{{form.metadataUrl.url}}",
          "providerId": "saml",
          "realm": "{{context.keycloak.realm}}"
        }
      },
      "onSuccess": [
        {
          "setState": {
            "metadata": {
              "$merge": ["constants.SamlIDPDefaults", "{{response.data}}"]
            },
            "formValid": true
          }
        },
        {
          "disableFormsInGroup": "metadataInput",
          "except": "metadataUrl"
        }
      ],
      "messages": {
        "success": "Configuration successfully validated with SAML. Continue to next step.",
        "error": "Configuration validation failed with SAML. Check URL and try again."
      }
    },
    "validateMetadataFile": {
      "type": "http",
      "request": {
        "method": "POST",
        "urlRef": "context.api.identifierURL",
        "bodyType": "formData",
        "body": {
          "providerId": "saml",
          "file": "{{form.metadataFile.metadataFile}}"
        }
      },
      "onSuccess": [
        {
          "setState": {
            "metadata": {
              "$merge": ["constants.SamlIDPDefaults", "{{response.data}}"]
            },
            "formValid": true
          }
        },
        {
          "disableFormsInGroup": "metadataInput",
          "except": "metadataFile"
        }
      ],
      "messages": {
        "success": "Configuration successfully validated with SAML. Continue to next step.",
        "error": "Configuration validation failed with SAML. Check file and try again."
      }
    },
    "validateMetadataConfig": {
      "type": "http",
      "request": {
        "method": "POST",
        "urlRef": "context.api.identifierURL",
        "bodyType": "formData",
        "body": {
          "providerId": "saml",
          "file": "{{form.metadataConfig.metadataFile}}",
          "ssoUrl": "{{form.metadataConfig.ssoUrl}}",
          "entityId": "{{form.metadataConfig.entityId}}"
        }
      },
      "onSuccess": [
        {
          "setState": {
            "metadata": {
              "$merge": ["constants.SamlIDPDefaults", "{{response.data}}"]
            },
            "formValid": true
          }
        },
        {
          "disableFormsInGroup": "metadataInput",
          "except": "metadataConfig"
        }
      ],
      "messages": {
        "success": "Configuration successfully validated with SAML. Continue to next step.",
        "error": "Configuration validation failed with SAML. Check values and try again."
      }
    },
    "createIdp": {
      "type": "keycloak.identityProvider.create",
      "request": {
        "urlRef": "context.api.createIdPUrl",
        "body": {
          "alias": "{{context.api.alias}}",
          "displayName": "{{context.displayName}}",
          "providerId": "saml",
          "hideOnLogin": true,
          "config": "{{state.metadata}}",
          "trustEmail": "{{context.featureFlags.trustEmail}}"
        }
      },
      "onSuccess": [
        {
          "setState": {
            "results": "Saml Identity Provider created successfully. Click finish.",
            "error": false,
            "disableButton": true,
            "stepIdReached": "wizard.finishStep"
          }
        },
        {
          "action": "samlAttributeMapper"
        },
        {
          "action": "checkPendingValidationStatus"
        },
        {
          "action": "clearAlias"
        }
      ],
      "onError": [
        {
          "setState": {
            "results": "Error creating Saml Identity Provider. Please confirm there is no SAML configured already.",
            "error": true
          }
        }
      ]
    },
    "samlAttributeMapper": {
      "type": "keycloak.identityProvider.samlAttributeMapper",
      "request": {
        "urlRef": "context.api.createIdPUrl",
        "aliasRef": "context.api.alias",
        "attributes": [
          {
            "attributeName": "username",
            "friendlyName": "username",
            "userAttribute": "username"
          },
          { "attributeName": "email", "friendlyName": "email", "userAttribute": "email" },
          {
            "attributeName": "firstName",
            "friendlyName": "firstName",
            "userAttribute": "firstName"
          },
          { "attributeName": "lastName", "friendlyName": "lastName", "userAttribute": "lastName" }
        ],
        "featureFlags": {
          "emailAsUsername": "{{context.featureFlags.emailAsUsername}}",
          "usernameMapperImport": "{{context.featureFlags.usernameMapperImport}}"
        }
      }
    },
    "checkPendingValidationStatus": {
      "type": "idpTestLink.checkPending",
      "request": {
        "aliasRef": "context.api.alias"
      },
      "onSuccess": [
        {
          "setState": { "idpTestLink": "{{response.link}}" }
        }
      ]
    },
    "clearAlias": {
      "type": "storage.remove",
      "request": {
        "key": "{{alias.storageKey}}"
      }
    },
    "navigateToBasePath": {
      "type": "navigation.gotoBasePath"
    }
  }
}
